{
  "name": "example-basic",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm pocketbase:start\" \"pnpm start:dev\"",
    "start:dev": "concurrently \"velite --watch\" \"vite dev\"",
    "build": "velite && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src/lib/conference-guide-content.test.ts src/lib/conference-guide.test.ts src/lib/mcp-public-contract.test.ts src/lib/mcp-token-utils.test.ts src/lib/mcp-token-policy.test.ts src/lib/mcp-auth.test.ts src/lib/mcp-scope-migration.test.ts src/lib/mcp-program-data.test.ts src/lib/mcp-contract.test.ts src/lib/mcp-partner-administration.test.ts src/lib/mcp-partner-tracer.test.ts src/lib/mcp-token-administration.test.ts src/lib/admin-actions.test.ts src/lib/admin-action-ledger.test.ts src/lib/admin-session-publication.test.ts src/lib/programme.test.ts src/lib/partners-public.test.ts src/lib/partner-administration.test.ts src/lib/gamification.test.ts",
    "start": "vite start",
    "version": "vite version",
    "pocketbase:download": "bash pocketbase/get-pocketbase.sh",
    "pocketbase:start": "bash pocketbase/start-local.sh",
    "pocketbase:createsuperuser": "bash pocketbase/create-superuser.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "generate:pb-types": "echo 'Manual type definition required. Update src/lib/pocketbase-types.ts based on your PocketBase collections.'"
  },
  "dependencies": {
    "@iconify-icon/solid": "^3.0.3",
    "@mdx-js/mdx": "^3.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solid-primitives/storage": "^4.3.4",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@solidjs/start": "2.0.0-alpha.2",
    "@solidjs/vite-plugin-nitro-2": "^0.1.0",
    "@types/spark-md5": "^3.0.5",
    "dotenv": "^17.4.0",
    "isomorphic-dompurify": "^3.15.0",
    "lottie-web": "^5.13.0",
    "pocketbase": "^0.26.8",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "solid-js": "^1.9.12",
    "solid-jsx": "^1.1.4",
    "spark-md5": "^3.0.2",
    "vite": "^7.3.1",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.12.0",
    "baseline-browser-mapping": "^2.10.13",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "postcss": "^8.5.8",
    "sqlite3": "^5.1.7",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "velite": "^0.3.1",
    "vite-plugin-solid-svg": "^0.8.1",
    "vitest": "^4.1.9"
  }
}
