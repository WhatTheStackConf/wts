# PocketBase — server admin API (internal hostname in Docker)
POCKETBASE_URL=http://127.0.0.1:8090

# Browser-facing PocketBase URL (file URLs, client SDK). Unset → http://127.0.0.1:8090
PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Canonical public site origin for absolute metadata URLs.
PUBLIC_SITE_URL=https://wts.sh

# Optional comma-separated browser Origins allowed to call MCP. Server/native clients omit Origin.
MCP_ALLOWED_ORIGINS=

POCKETBASE_SUPERUSER_EMAIL=admin@example.com
POCKETBASE_SUPERUSER_PASSWORD=supersecret

# Server-only HMAC pepper for Mission-code hashing and request fingerprints.
# Generate a high-entropy value; never expose it through PUBLIC_ or VITE_ variables.
GAMIFICATION_CODE_PEPPER=replace-with-a-random-secret

# Public values baked into the browser bundle during the Docker build.
VITE_LISTMONK_LIST_ID=2
VITE_TURNSTILE_SITE_KEY=

# Server-only Hi.Events evidence source. Use either API_KEY or the login fields.
HIEVENTS_API_URL=https://hievents.example.com
HIEVENTS_API_KEY=
HIEVENTS_EVENT_ID=1
HIEVENTS_EMAIL=
HIEVENTS_PASSWORD=
HIEVENTS_ACCOUNT_ID=1
HIEVENTS_REQUEST_TIMEOUT_MS=10000
HIEVENTS_STATUS_STALE_MS=21600000

# Production example:
# PUBLIC_POCKETBASE_URL=https://pb-2026.wts.sh
# POCKETBASE_URL=http://pocketbase:8090
