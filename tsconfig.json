{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "@solidjs/start/env",
      "vite-plugin-solid-svg/types",
      "vite/client",
      "node"
    ],
    "isolatedModules": true,
    "paths": {
      "~/*": [
        "./src/*"
      ],
      ".velite": [
        "./.velite"
      ]
    }
  },
  "include": [
    "src",
    "vite.config.ts"
  ]
}
